{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "*": ["../node_modules/*", "../artifacts/api-server/node_modules/*"]
    }
  },
  "include": ["./**/*.ts", "../artifacts/api-server/src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
